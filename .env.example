PORT=4000
CORS_ORIGIN=http://localhost:5173
TARGET_AMOUNT=250000000

# Đổi thành chuỗi bí mật của riêng bạn trước khi deploy
ADMIN_TOKEN=change-me-admin-token

# Dùng khi nối webhook Casso/SePay thật (xem server/README.md)
WEBHOOK_SECRET=change-me-webhook-secret

# Turso (libSQL hosted) — xem DEPLOY.md để tạo database
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=
